# Gateway wallet — receives payments (server)
GATEWAY_SEED_PHRASE="your twelve word seed phrase here"

# Facilitator wallet — submits settlement txs on Plasma (needs native gas)
# Falls back to GATEWAY_SEED_PHRASE if not set
FACILITATOR_SEED_PHRASE="your twelve word seed phrase here"

# AI backend (Groq)
GROQ_API_KEY="gsk_..."

# Treasury agent wallet — bridges idle USDT0 to Arbitrum for Aave yield
# Can be the same as GATEWAY_SEED_PHRASE for demo
TREASURY_SEED_PHRASE="your twelve word seed phrase here"

# Client wallets — need USDT0 on Plasma to pay
CLIENT_SEED_PHRASE="your twelve word seed phrase here"
RESEARCHER_SEED_PHRASE="another twelve word seed phrase here"  # for multi-agent demo; falls back to CLIENT_SEED_PHRASE

# OpenClaw agent wallet (loaded by WDK skill)
WALLET_SEED_PHRASE="your twelve word seed phrase here"

# Network: "plasma" (mainnet, USDT0) or "base-sepolia" (testnet, USDC — free faucet)
# Testnet faucets:
#   ETH on Base Sepolia: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
#   USDC on Base Sepolia: https://faucet.circle.com
NETWORK=base-sepolia

# Server
PORT=4021
GATEWAY_URL=http://localhost:4021  # override if deploying remotely

# Research topic for multi-agent demo (optional)
RESEARCH_TOPIC="How does the x402 payment protocol enable autonomous AI agent economies?"

# Pricing (in USDT0 micro-units, 6 decimals — 1000 = $0.001)
PRICE_SMALL=200
PRICE_MEDIUM=1000
PRICE_LARGE=2000
